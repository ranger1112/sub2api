# =============================================================================
# Sub2API Deploy Directory - Git Ignore
# =============================================================================

# Data directories (generated at runtime when using docker-compose.local.yml)
data/
postgres_data/
redis_data/

# Environment configuration (contains sensitive information)
.env

# Backup files
*.backup
*.bak

# Temporary files
*.tmp
*.log

# Exported image archives (docker save artifacts, e.g. sub2api-<branch>-<commit>-linux-amd64.tar)
*.tar
*.tar.gz
*.tgz
